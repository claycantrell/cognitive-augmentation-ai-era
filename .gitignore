*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz

# Papis cache
library/**/cache/

# nb internals
.nb/

# Scratch (brainstorming space — git-ignored by default)
scratch/*
!scratch/README.md

# Node (for scite-cli)
node_modules/

