# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
# .vscode/ is intentionally tracked — it contains shared project settings
.idea/

# Environment
.env
.venv/
venv/
__pycache__/
*.pyc

# Build output (generated by `make pdf`, `make docx`, etc.)
output/*
!output/.gitkeep

# LaTeX intermediates
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz

# Papis cache
library/**/cache/

# nb internals
.nb/

# Scratch (brainstorming space — git-ignored by default)
scratch/*
!scratch/README.md

# Node (for scite-cli)
node_modules/

# Uncomment to stop tracking source PDFs (they can be large):
# sources/*.pdf
