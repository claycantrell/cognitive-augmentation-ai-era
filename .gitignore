*.pyc

# Build output — keep final manuscripts, ignore intermediates
output/*.aux
output/*.log
output/*.out
output/*.toc
output/*.bbl
output/*.blg
output/*.fdb_latexmk
output/*.fls
output/*.synctex.gz

